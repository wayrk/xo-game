{
  "name": "xo-game-desktop",
  "version": "1.0.0",
  "description": "XO Tic-Tac-Toe Desktop",
  "main": "main.js",
  "author": "OpenClaw",
  "scripts": {
    "dist:win": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "ai.openclaw.xo",
    "productName": "XO-Game",
    "files": [
      "main.js",
      "www/**/*",
      "build/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "XO-Game-${version}-portable.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "wayrk",
        "repo": "xo-game"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "XO-Game-Setup-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}